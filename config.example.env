# Dropbox OAuth2 credentials
# Create a Dropbox app with access to the folder structure you want to use.
DROPBOX_APP_KEY=your_app_key_here
DROPBOX_APP_SECRET=your_app_secret_here
DROPBOX_REFRESH_TOKEN=your_refresh_token_here

# Storage mode: choose one.

# Option A: single event folder
# The folder must contain event.json.
DROPBOX_FOLDER_PATH=/MediaPool/ExampleEvent

# Option B: multi-event mode
# Each direct child folder must contain event.json.
# DROPBOX_GROUPS_ROOT=/MediaPool

# Auth
# Generate with:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_a_long_random_string

# PIN for the admin QR page.
ADMIN_PIN=change_me

# Server
PORT=7000

# Public URL
# Set this when hosting externally so QR links use the public domain.
# Include the scheme and omit the trailing slash.
# Example (Azure public IP): PUBLIC_URL=http://203.0.113.10:7000
# Example (HTTPS domain): PUBLIC_URL=https://mediapool.example.com
# PUBLIC_URL=

# Set to 1 only when debugging malformed HTTP traffic. Public VMs often receive
# scanner or HTTPS-handshake noise on plain HTTP ports, so these warnings are
# hidden by default in the launcher.
# SHOW_INVALID_HTTP_WARNINGS=0

# Runtime safety defaults for Azure/local hosting.
# "active" user count means sessions touched within this many minutes.
ACTIVE_ONLINE_MINUTES=30

# Server-side upload processing cap. The browser also uploads two files at a time.
UPLOAD_PROCESSING_LIMIT=2
BLOCKING_WORK_LIMIT=8
MAX_PHOTO_UPLOAD_MB=75
MAX_VIDEO_UPLOAD_MB=500
MAX_ZIP_FILES=50
MAX_ZIP_TOTAL_MB=1024
MAX_HIGHLIGHT_FILES=20
HIGHLIGHT_FFMPEG_TIMEOUT_SECONDS=180

# Optional AI / Arena integration
# ARENA_URL=http://localhost:6059
# ARENA_TOKEN=your_arena_token_here
# ARENA_USER=your_arena_username_here
# ARENA_PASS=your_arena_password_here

# Caption model — must support vision (image input).
# If the primary model returns HTTP 422, CAPTION_MODEL_FALLBACK is tried automatically.
# CAPTION_MODEL=gpt-5.4-nano
# CAPTION_MODEL_FALLBACK=gpt-5.4-pro
